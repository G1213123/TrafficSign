{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug with Server",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080/design",
            "webRoot": "${workspaceFolder}",
            "pathMapping": {
                "/design": "${workspaceFolder}"
            },
            "skipFiles": [
                // Existing pattern
                "**VM**",
                // Local dependencies
                "${workspaceFolder}/node_modules/**",
                // Paper.js (local copy if ever added) and CDN version
                "**/paper-full.min.js",
                "https://cdnjs.cloudflare.com/ajax/libs/paper.js/**",
                // All Google ads / tag / measurement / quality helper scripts (consolidated)
                "**/sodar2.js",
                "**/adsbygoogle.js**",
                "**/show_ads_**",
                "*googlesyndication*",
                // Eval / anonymous script frames
                "<eval>/**",
                // Specific VM eval chunks (e.g. <eval>/VM46947695)
                "<eval>/VM**",
                "<anonymous>/**"
            ]
        },
    ]
}